{
  "name": "@claudecord/bot",
  "version": "0.1.0",
  "private": true,
  "description": "The claudecord bot process: Discord client, Claude Agent SDK runner and admin dashboard server.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.199",
    "@hono/node-server": "^2.0.8",
    "better-sqlite3": "^12.11.1",
    "discord.js": "^14.26.4",
    "hono": "^4.12.27",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.5",
    "vitest": "^4.1.9"
  }
}
