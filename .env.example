# ── Claude authentication ────────────────────────────────────────────────
# Recommended: a Claude Code OAuth token from your Pro/Max subscription.
# Generate one on any machine with Claude Code installed:
#   claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# Alternative: a Claude Console API key (pay-as-you-go). Only used when
# CLAUDE_CODE_OAUTH_TOKEN is not set.
# ANTHROPIC_API_KEY=

# ── Discord ──────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
# Remember to enable the "Message Content Intent" on the Bot page!
DISCORD_BOT_TOKEN=

# Application (client) ID — used to register slash commands and build the
# invite URL shown in the dashboard.
DISCORD_APPLICATION_ID=

# ── GitHub integration (optional) ────────────────────────────────────────
# A GitHub token lets agentic threads use `git` and the `gh` CLI to clone,
# read, push and open pull requests on the repositories the token reaches.
# Only takes effect in agentic mode. You can also set this in the dashboard.
#
# Recommended: a fine-grained token (github.com/settings/tokens?type=beta)
# scoped to the specific repos, with these repository permissions:
#   Contents        Read (or Read & write to push commits/branches)
#   Pull requests   Read & write
#   Metadata        Read (mandatory)
#   Issues          Read & write (optional)
# A classic PAT with the `repo` scope also works but grants far broader access.
# GITHUB_TOKEN=

# ── Per-user GitHub (multi-user, optional) ───────────────────────────────
# Register a GitHub App (Settings → Developer settings → GitHub Apps) with
# "Enable Device Flow" checked. Role-gated Discord users then run /link-github
# to connect their OWN GitHub account via the OAuth Device Flow; agentic runs
# act in the acting user's namespace instead of using the shared GITHUB_TOKEN.
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=

# ── Dashboard ────────────────────────────────────────────────────────────
# The admin dashboard binds to localhost by default. If you expose it on
# another interface, DASHBOARD_PASSWORD becomes mandatory.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=3000
# DASHBOARD_PASSWORD=
# DASHBOARD_INSECURE_BIND=false  # allow a public bind without a password —
#                                 # only for containers whose port is mapped
#                                 # to the host's loopback (docker-compose default)

# ── Bot behaviour ────────────────────────────────────────────────────────
# Default model for new conversations. Admins can override per guild.
CLAUDE_MODEL=claude-sonnet-5

# Where SQLite, per-thread workspaces and other state live.
DATA_DIR=./data

# Maximum Claude runs across all guilds at once (each run is a subprocess).
MAX_CONCURRENT_RUNS=4

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
